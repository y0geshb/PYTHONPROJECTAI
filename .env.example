# ---------------------------------------------------------------
# SERH API Test Automation Framework – Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. It is listed in .gitignore.
# ---------------------------------------------------------------

# Target API base URL (no trailing slash)
API_BASE_URL=https://your-api-base-url.com

# Login endpoint path
API_LOGIN_ENDPOINT=/api/auth/login

# QA test user credentials (used by live positive tests only)
API_USER_EMAIL=your-test-email@example.com
API_USER_PASSWORD=your-test-password

# Admin user credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# Captcha token for live positive tests
SERH_CAPTCHA_TOKEN=your-captcha-token

# Refresh token for refresh-token endpoint tests
SERH_REFRESH_TOKEN=replace-with-valid-refresh-token

# Session token for OTP verification tests
SERH_FORGOT_OTP_SESSION_TOKEN=replace-with-session-token

# Reset token for password reset tests
SERH_RESET_TOKEN=replace-with-reset-token

# New password used in reset flow tests
SERH_NEW_PASSWORD=replace-with-new-password

# Unlock token for account-unlock tests
SERH_UNLOCK_TOKEN=replace-with-unlock-token

# Mock server valid credentials (for mock_server only)
MOCK_VALID_EMAIL=qa.mock.user@testdomain.com
MOCK_VALID_PASSWORD=MockPass#0000

# Enable live positive tests (set to true to run TC_LOGIN_001 etc. against real API)
SERH_ENABLE_LIVE_POSITIVE=false

# GitHub automation (used by setup_github.py)
GITHUB_REPO_URL=https://github.com/y0geshb/PYTHONPROJECTAI.git
GIT_BRANCH=main
GIT_USER_NAME=your-github-username
GIT_USER_EMAIL=your-email@example.com
