# Environment and secrets — NEVER commit these files
.env
*.pem
*.key
*.p12
*.pfx
secrets.json
secrets.yaml
config.local.py
.env.local
.env.*.local

# Virtual environment
venv/
env/
.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyc

# pytest cache
.pytest_cache/

# Test reports
reports/*.html
reports/*.json
allure-results/

# IDE settings
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db

# Archived legacy files
Archieve/
Archieves/

# Broken git metadata backups (created by setup_github.py recovery)
.git.broken.*

