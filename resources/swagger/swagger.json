{
  "openapi": "3.0.3",
  "info": {
    "title": "Al Warra Auth Service API",
    "version": "1.0.0",
    "description": "APNEW-2 authentication contracts (FR-1 to FR-10). Runtime base path is /api/auth."
  },
  "servers": [
    {
      "url": "/api/auth"
    }
  ],
  "tags": [
    { "name": "Authentication" },
    { "name": "Password Recovery" },
    { "name": "Sessions" },
    { "name": "SSO" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorObject": {
        "type": "object",
        "required": ["code", "details", "fields"],
        "properties": {
          "code": { "type": "string" },
          "details": { "type": "array", "items": { "type": "string" } },
          "fields": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      },
      "LocalizedMessage": {
        "type": "object",
        "required": ["en", "ar"],
        "properties": {
          "en": { "type": "string" },
          "ar": { "type": "string" }
        }
      },
      "SuccessEnvelope": {
        "type": "object",
        "required": ["success", "message", "data"],
        "properties": {
          "success": { "type": "boolean", "enum": [true] },
          "message": { "$ref": "#/components/schemas/LocalizedMessage" },
          "data": { "type": "object" }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "required": ["success", "message", "error"],
        "properties": {
          "success": { "type": "boolean", "enum": [false] },
          "message": { "$ref": "#/components/schemas/LocalizedMessage" },
          "error": { "$ref": "#/components/schemas/ErrorObject" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password", "captchaToken"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 10, "maxLength": 128 },
          "captchaToken": { "type": "string", "minLength": 3 }
        }
      },
      "MfaChallengeData": {
        "type": "object",
        "required": ["mfaRequired", "mfaSessionToken"],
        "properties": {
          "mfaRequired": { "type": "boolean", "enum": [true] },
          "mfaSessionToken": { "type": "string", "description": "Short-lived signed JWT submitted with OTP in the verify step. Expires after otpTtlSeconds (default 5 min)." }
        }
      },
      "MfaVerifyRequest": {
        "type": "object",
        "required": ["mfaSessionToken", "otp"],
        "properties": {
          "mfaSessionToken": { "type": "string", "description": "Token received from POST /login" },
          "otp": { "type": "string", "pattern": "^[0-9]{6}$", "description": "6-digit numeric OTP sent to the user's email" }
        }
      },
      "MfaVerifyData": {
        "type": "object",
        "required": ["authToken", "refreshToken", "accountStatus"],
        "properties": {
          "authToken": { "type": "string" },
          "refreshToken": { "type": "string" },
          "accountStatus": { "type": "string", "enum": ["ACTIVE", "LOCKED", "INACTIVE"] }
        }
      },
      "RefreshRequest": {
        "type": "object",
        "required": ["refreshToken"],
        "properties": {
          "refreshToken": { "type": "string" }
        }
      },
      "TokenPairData": {
        "type": "object",
        "required": ["authToken", "refreshToken"],
        "properties": {
          "authToken": { "type": "string" },
          "refreshToken": { "type": "string" }
        }
      },
      "UaePassStartData": {
        "type": "object",
        "required": ["redirectUrl", "state"],
        "properties": {
          "redirectUrl": { "type": "string", "format": "uri" },
          "state": { "type": "string" }
        }
      },
      "UaePassCallbackRequest": {
        "type": "object",
        "required": ["state"],
        "oneOf": [
          { "required": ["code"] },
          { "required": ["error"] }
        ],
        "properties": {
          "state": { "type": "string", "description": "CSRF state token generated by the server" },
          "code": { "type": "string", "description": "Authorization code returned by UAE PASS" },
          "error": { "type": "string", "description": "OAuth error code if authorization failed" },
          "error_description": { "type": "string", "description": "Human-readable OAuth error description" }
        }
      },
      "UaePassCallbackData": {
        "type": "object",
        "required": ["linkingRequired"],
        "properties": {
          "authToken": { "type": "string", "description": "JWT access token" },
          "refreshToken": { "type": "string", "description": "JWT refresh token" },
          "linkingRequired": { "type": "boolean", "description": "True if UAE PASS subject is not yet linked to a portal account" }
        }
      },
      "UaePassLogoutData": {
        "type": "object",
        "required": ["logoutUrl"],
        "properties": {
          "logoutUrl": { "type": "string", "format": "uri", "description": "UAE PASS logout redirect URL; frontend must redirect user to this URL to complete SSO logout" }
        }
      },
      "ForgotEmailRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" }
        }
      },
      "ForgotEmailData": {
        "type": "object",
        "required": ["accepted", "resetToken", "resetUrl"],
        "properties": {
          "accepted": { "type": "boolean" },
          "resetToken": { "type": "string", "nullable": true },
          "resetUrl": { "type": "string", "nullable": true }
        }
      },
      "ForgotOtpInitiateRequest": {
        "type": "object",
        "required": ["mobile"],
        "properties": {
          "mobile": { "type": "string", "minLength": 7, "maxLength": 30 }
        }
      },
      "ForgotOtpInitiateData": {
        "type": "object",
        "required": ["accepted", "sessionToken", "otp", "delivery"],
        "properties": {
          "accepted": { "type": "boolean" },
          "sessionToken": { "type": "string" },
          "otp": { "type": "string" },
          "delivery": { "type": "string" }
        }
      },
      "ForgotOtpVerifyRequest": {
        "type": "object",
        "required": ["sessionToken", "otp"],
        "properties": {
          "sessionToken": { "type": "string" },
          "otp": { "type": "string", "minLength": 4, "maxLength": 10 }
        }
      },
      "ForgotOtpVerifyData": {
        "type": "object",
        "required": ["resetToken"],
        "properties": {
          "resetToken": { "type": "string" }
        }
      },
      "PasswordResetRequest": {
        "type": "object",
        "required": ["resetToken", "newPassword"],
        "properties": {
          "resetToken": { "type": "string" },
          "newPassword": { "type": "string", "minLength": 10, "maxLength": 128 }
        }
      },
      "PasswordResetData": {
        "type": "object",
        "required": ["completed"],
        "properties": {
          "completed": { "type": "boolean" }
        }
      },
      "UnlockRequest": {
        "type": "object",
        "required": ["unlockToken"],
        "properties": {
          "unlockToken": { "type": "string" }
        }
      },
      "UnlockData": {
        "type": "object",
        "required": ["unlocked"],
        "properties": {
          "unlocked": { "type": "boolean" }
        }
      },
      "LogoutRequest": {
        "type": "object",
        "required": ["refreshToken"],
        "properties": {
          "refreshToken": { "type": "string" }
        }
      },
      "LogoutData": {
        "type": "object",
        "required": ["loggedOut"],
        "properties": {
          "loggedOut": { "type": "boolean" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "NotFound": {
        "description": "Not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "Conflict": {
        "description": "Conflict",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "Validation": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "Locked": {
        "description": "Account locked",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      }
    }
  },
  "paths": {
    "/login": {
      "post": {
        "summary": "Email/password login — Step 1 of 2 (MFA)",
        "description": "FR-1 + FR-6. Validates CAPTCHA and credentials. On success, sends a 6-digit OTP to the user's registered email and returns an MFA session token. The client must submit the OTP to POST /login/mfa/verify to receive JWT tokens.",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Credentials valid — OTP sent to email",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/MfaChallengeData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/Validation" },
          "423": { "$ref": "#/components/responses/Locked" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/login/mfa/verify": {
      "post": {
        "summary": "MFA OTP verify — Step 2 of 2",
        "description": "Validates the MFA session token and 6-digit OTP sent to the user's email. On success, issues a JWT access/refresh token pair and completes login.",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MfaVerifyRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP verified — JWT token pair issued",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/MfaVerifyData" } } }
                  ]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "422": { "$ref": "#/components/responses/Validation" },
          "423": { "$ref": "#/components/responses/Locked" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/refresh": {
      "post": {
        "summary": "Refresh token rotation",
        "description": "FR-9. Rotates refresh tokens and returns a new access/refresh pair.",
        "tags": ["Sessions"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RefreshRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rotated",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/TokenPairData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/Validation" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/uae-pass/start": {
      "get": {
        "summary": "UAE PASS SSO login initiation",
        "description": "FR-2. Generates PKCE state+nonce, returns the UAE PASS QA authorization redirect URL. Frontend must redirect the user to the returned redirectUrl to start the OAuth2 Authorization Code flow.",
        "tags": ["SSO"],
        "security": [],
        "responses": {
          "200": {
            "description": "Redirect payload with UAE PASS authorization URL",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/UaePassStartData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/uae-pass/callback": {
      "get": {
        "summary": "UAE PASS OAuth2 callback",
        "description": "FR-2 + FR-8. Handles OAuth2 Authorization Code callback from UAE PASS. Validates state, exchanges code for access_token, fetches user profile from userinfo endpoint, maps to portal user, and issues JWT tokens.",
        "tags": ["SSO"],
        "security": [],
        "parameters": [
          { "in": "query", "name": "state", "required": true, "schema": { "type": "string" }, "description": "CSRF state value generated by /uae-pass/start" },
          { "in": "query", "name": "code", "required": false, "schema": { "type": "string" }, "description": "Authorization code from UAE PASS (present on success)" },
          { "in": "query", "name": "error", "required": false, "schema": { "type": "string", "enum": ["access_denied", "invalid_request", "login_required", "invalid_scope"] }, "description": "OAuth error code (present on authorization failure)" },
          { "in": "query", "name": "error_description", "required": false, "schema": { "type": "string" }, "description": "Human-readable description of the OAuth error" }
        ],
        "responses": {
          "200": {
            "description": "JWT token pair issued",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/UaePassCallbackData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/Validation" },
          "502": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "post": {
        "summary": "UAE PASS OAuth2 callback (POST variant)",
        "description": "Provider-driven POST callback variant for UAE PASS. Same logic as GET callback.",
        "tags": ["SSO"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UaePassCallbackRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JWT token pair issued",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/UaePassCallbackData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/Validation" },
          "502": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/uae-pass/logout": {
      "post": {
        "summary": "UAE PASS SSO logout",
        "description": "Revokes all local JWT sessions for the authenticated user and returns the UAE PASS OIDC logout URL. Frontend must redirect the user to the returned logoutUrl to complete SSO session termination.",
        "tags": ["SSO"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Local sessions revoked; UAE PASS logout URL returned",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/UaePassLogoutData" } } }
                  ]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/password/forgot-email": {
      "post": {
        "summary": "Forgot password via email",
        "description": "FR-3. Creates single-use email reset token with anti-enumeration response.",
        "tags": ["Password Recovery"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ForgotEmailRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/ForgotEmailData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/Validation" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/password/forgot-otp/initiate": {
      "post": {
        "summary": "Forgot password OTP initiate",
        "description": "FR-4. Starts OTP verification flow with masked delivery metadata.",
        "tags": ["Password Recovery"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ForgotOtpInitiateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/ForgotOtpInitiateData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/Validation" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/password/forgot-otp/verify": {
      "post": {
        "summary": "Forgot password OTP verify",
        "description": "FR-4. Verifies OTP and issues reset token grant.",
        "tags": ["Password Recovery"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ForgotOtpVerifyRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verified",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/ForgotOtpVerifyData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/Validation" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/password/reset": {
      "post": {
        "summary": "Commit password reset",
        "description": "FR-3/FR-4. Final reset commit; revokes active sessions.",
        "tags": ["Password Recovery"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PasswordResetRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Completed",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/PasswordResetData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/Validation" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/account/unlock": {
      "post": {
        "summary": "Unlock account",
        "description": "FR-7. Unlocks account with verified unlock token and resets failure counter.",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UnlockRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Unlocked",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/SuccessEnvelope" },
                    { "properties": { "data": { "$ref": "#/components/schemas/UnlockData" } } }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/Validation" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/logout": {
      "post": {
        "summary": "Logout and revoke session",
        "description": "FR-9. Revokes active refresh session. Requires bearer access token.",
        "tags": ["Sessions"],
